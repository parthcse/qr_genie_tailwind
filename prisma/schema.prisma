datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum QrStatus {
  ACTIVE
  PAUSED
  DELETED
}

enum LinkType {
  STATIC
  DYNAMIC
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  password              String
  name                  String?
  role                  String    @default("user")
  plan                  String    @default("free")   // legacy
  trialEndsAt           DateTime?
  resetToken            String?
  resetTokenExpires     DateTime?
  subscriptionPlan      String    @default("EXPIRED") // TRIAL | BASIC | EXPIRED
  trialStartedAt        DateTime?
  subscriptionStartedAt DateTime?
  subscriptionEndsAt    DateTime?
  
  // General Information (Account)
  telephone             String?
  company               String?
  address               String?
  city                  String?
  state                 String?
  zipCode               String?
  country               String?
  language              String?  @default("English")
  
  // Billing Information
  billingName           String?
  billingCompany        String?
  billingAddress        String?
  billingCity           String?
  billingState          String?
  billingZipCode        String?
  billingCountry        String?
  taxId                 String?
  
  qrCodes               QRCode[]
  folders               Folder[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model QRCode {
  id                String    @id @default(cuid())
  slug              String    @unique
  type              String    @default("website")
  targetUrl         String
  name              String?
  qrColor           String    @default("#000000")
  bgColor           String    @default("#ffffff")
  meta              String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  scanCount         Int       @default(0)
  isActive          Boolean   @default(true) // legacy; kept for backward compat, synced from status
  deactivatedReason String?   // TRIAL_EXPIRED | SUBSCRIPTION_EXPIRED | MANUAL | null
  status            QrStatus  @default(ACTIVE) // ACTIVE | PAUSED | DELETED
  linkType          LinkType  @default(DYNAMIC) // STATIC = no tracking, DYNAMIC = /r/slug + tracking
  pausedMessage    String?   // configurable "QR paused" landing text
  user              User?     @relation(fields: [userId], references: [id])
  userId            String?
  folder            Folder?   @relation(fields: [folderId], references: [id])
  folderId          String?
  scanEvents        ScanEvent[]
}

model ScanEvent {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  userAgent       String?
  ip              String?  // optional truncated IP; prefer ipHash for privacy
  ipHash          String?  // hashed IP for unique counts and privacy
  os              String?
  deviceType     String?  // mobile | desktop | tablet
  browser         String?
  referer         String?
  country         String?
  region          String?
  city            String?
  blockedByStatus Boolean  @default(false) // true when hit was to a paused QR (if we log it)

  qrCode    QRCode @relation(fields: [qrCodeId], references: [id])
  qrCodeId  String
}


model Folder {
  id        String   @id @default(cuid())
  name      String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  qrCodes   QRCode[]
  createdAt DateTime @default(now())
}

